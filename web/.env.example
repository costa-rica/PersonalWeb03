# Environment Variables Configuration Template
# Copy this file to .env.local and fill in the values

# ============================================================================
# REQUIRED VARIABLES
# ============================================================================
# These variables MUST be set for the application to build and run.
# The build will fail if any of these are missing or invalid.

# Backend API Base URL
# The base URL for the FastAPI backend server
# Examples:
#   - Development: http://localhost:8000
#   - Production: https://api.yoursite.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Application Mode
# Determines the runtime environment and behavior
# Valid values: development | production | test
NEXT_PUBLIC_MODE=production

# Application Name
# Used for logging and identification
# Example: PersonalWeb03-NextJS
NEXT_PUBLIC_NAME_APP=PersonalWeb03-NextJS

# Logs Directory Path
# Absolute path to the directory where application logs will be stored
# Examples:
#   - Development: /Users/username/Documents/_logs
#   - Production: /var/log/personalweb03
PATH_TO_LOGS=/var/log/personalweb03

# Display Hours Spent Table
# Controls whether the project hours table is displayed in the hero section
# Valid values: true | false (lowercase only)
NEXT_PUBLIC_DISPLAY_HOURS_SPENT=true

# ============================================================================
# OPTIONAL VARIABLES
# ============================================================================
# These variables have sensible defaults and are not required

# Server Port (default: 3001)
# PORT=3001

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file:
#    cp .env.example .env.local
#
# 2. Edit .env.local and fill in the values above
#
# 3. Verify your configuration:
#    npm run build
#
# 4. Start development server:
#    npm run dev
#
# Note: .env.local is gitignored and will not be committed to version control
